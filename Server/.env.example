# ---- Storage ----
# 'local' (default) keeps using Server/inputs and Server/outputs on disk.
# 's3' routes all inputs/outputs through the S3 bucket below.
STORAGE_BACKEND=local
S3_BUCKET=landwise-results
S3_REGION=ap-south-1
S3_PRESIGN_EXPIRES=3600
# When 'true', local outputs/validate/<rid> and inputs/validate/<rid> are
# deleted after each run completes (and is uploaded to S3). Subsequent reads
# pull from S3 on demand. Leave 'false' until you've verified everything.
S3_CLEANUP_LOCAL_AFTER_RUN=false
AWS_ACCESS_KEY_ID=ASIATOT4F5IUTTD5UGFR
AWS_SECRET_ACCESS_KEY=1kE+7d5lAPq//x/6QNkHWD6oUz2K4gVCmsBt6ptM

