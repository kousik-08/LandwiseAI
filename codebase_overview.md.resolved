GEMINI_MODEL=gemini-2.5-flash-lite  # Default model
OLLAMA_URL=http://localhost:11434    # (currently unused in main flow)
VALIDATOR_MODEL=gemma3:1b           # (currently unused)
CHUNK_SIZE=8                        # EC pages per Gemini chunk
MATCH_LIMIT=50                      # Default max matched docs (0 = unlimited)
TNGIS_EC_API_URL=...
TNGIS_LANDINFO_API_URL=...
```

